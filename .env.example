# ─────────────────────────────────────────────────────────────────────────────
# Welldone AI Agent Team — Variables d'environnement
# Copier ce fichier en .env pour le développement local
# Pour Railway : configurer ces variables dans Settings > Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# BotFather → /newbot → copier le token
TELEGRAM_BOT_TOKEN=

# Ton user ID Telegram (obtenir via @userinfobot)
TELEGRAM_ALLOWED_USER_ID=8434904512

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Modèle à utiliser (défaut: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Google Service Account (GA4 + Search Console) ────────────────────────────
# COMMENT GÉNÉRER :
# 1. Google Cloud Console → IAM & Admin → Service Accounts
# 2. Créer un compte de service → Télécharger la clé JSON
# 3. Aller dans GA4 Admin → Gestion des accès → Ajouter le compte de service (Lecteur)
# 4. Aller dans Search Console → Paramètres → Utilisateurs → Ajouter (Propriétaire restreint)
# 5. Encoder: cat service_account.json | base64 | tr -d '\n' | pbcopy
GOOGLE_SA_JSON_B64=

# ── Google OAuth (Gmail + Calendar + Contacts) ────────────────────────────────
# COMMENT GÉNÉRER :
# 1. Google Cloud Console → Credentials → OAuth 2.0 Client ID
# 2. Activer les APIs: Gmail, Calendar, People
# 3. Depuis ce dossier, lancer le script de génération une fois en local :
#    python scripts/generate_oauth_token.py
# 4. Copier le contenu du fichier token.json généré
# 5. Coller le JSON brut (pas base64) dans cette variable
GOOGLE_OAUTH_JSON=

# ── Notion ────────────────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations → Créer une intégration → Copier le token
NOTION_TOKEN=

# ID de la database Tâches (visible dans l'URL Notion de la base)
NOTION_TASK_DB=bd4cff932b7842b19f7cb748e1abda48

# ID de la database Sources RSS pour la veille
NOTION_SOURCES_DB=10e87f01b8ec4c60a6383d48c7aac4a2

# ── Zoho Books ────────────────────────────────────────────────────────────────
# https://api-console.zoho.ca → Créer une Self Client → Scopes: ZohoBooks.fullaccess.all
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ORG_ID=110002477093

# Refresh token (obtenu une fois via OAuth, jamais d'expiration)
# Générer avec: python scripts/generate_zoho_token.py
ZOHO_REFRESH_TOKEN=

# ── Email ─────────────────────────────────────────────────────────────────────
# Destinataire des rapports automatiques
GMAIL_RECIPIENT=awelldonestudio@gmail.com

# ── Analytics ─────────────────────────────────────────────────────────────────
# ID de la propriété GA4 (visible dans GA4 Admin → Informations sur la propriété)
GA4_PROPERTY_ID=522467276

# ── OpenAI (Agent Voyage) ─────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
# Utilisé par l'agent voyage avec GPT-4o + function calling
OPENAI_API_KEY=

# ── SerpAPI (Google Flights) ──────────────────────────────────────────────────
# https://serpapi.com → Dashboard → API Key
# Utilisé par l'agent voyage pour les prix de vols en temps réel
SERPAPI_KEY=
