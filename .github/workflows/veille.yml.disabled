name: Veille hebdomadaire

on:
  schedule:
    # Lundi 8h00 heure de Montréal = 13h00 UTC
    - cron: '0 13 * * 1'
  workflow_dispatch: {}   # Déclenchement manuel depuis Telegram

jobs:
  veille:
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: pip install anthropic requests feedparser google-auth google-auth-oauthlib google-api-python-client

      - name: Reconstruct Google token
        run: |
          echo "${{ secrets.GOOGLE_TOKEN_JSON_B64 }}" | base64 -d > token.json

      - name: Run veille
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          NOTION_TOKEN: ${{ secrets.NOTION_TOKEN }}
          NOTION_SOURCES_DB: ${{ secrets.NOTION_SOURCES_DB }}
          FRAMER_API_KEY: ${{ secrets.FRAMER_API_KEY }}
          FRAMER_COLLECTION_ID: ${{ secrets.FRAMER_COLLECTION_ID }}
          GMAIL_TOKEN: token.json
          GMAIL_RECIPIENT: awelldonestudio@gmail.com
          GOOGLE_TOKEN_PATH: token.json
        run: python veille_lundi.py
